AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
FOUNDRY_RESOURCE_NAME=
FOUNDRY_PROJECT_NAME=
FOUNDRY_PROJECT_ENDPOINT=
AGENT_NAME=acl-remedy-advisor
AGENT_MODEL=chat
AGENT_VERSION=
HOSTED_AGENT_NAME_CONTAINER=acl-remedy-advisor-hosted-container
HOSTED_AGENT_NAME_CODE=acl-remedy-advisor-hosted-code
KNOWLEDGE_BASE_NAME=acl-remedy-knowledge
KNOWLEDGE_BASE_CONNECTION_NAME=
TOOLBOX_NAME=acl-remedy-toolbox
AZURE_OPENAI_ENDPOINT=
AZURE_SEARCH_SERVICE_NAME=
AZURE_SEARCH_PRODUCT_INDEX_NAME=retail-products
AZURE_SEARCH_DOCUMENT_INDEX_NAME=retail-policies
AZURE_SEARCH_PASSENGER_RIGHTS_INDEX_NAME=passenger-rights
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_REGISTRY_ENDPOINT=
AZURE_CONTAINER_APPS_DEPLOY=true

# Set to 'true' to activate individual mode: the deploying user becomes the sole attendee.
# AZURE_ATTENDEE_LIST is not required. The onboarding index upload and Attendee Onboarding Portal still run by default.
# .env is written automatically after provisioning.
AZURE_INDIVIDUAL_MODE=

# introduction-foundry-agent-service lab (retail-remedy-ops MCP server)
RETAIL_REMEDY_OPS_MCP_SERVER_PORT=8080
RETAIL_REMEDY_OPS_MCP_SERVER_URL=
RETAIL_REMEDY_OPS_MCP_SERVER_LABEL=retail_remedy_ops

# agent-framework-dotnet lab (flight-ops MCP server)
FLIGHT_OPS_MCP_SERVER_PORT=3001
FLIGHT_OPS_MCP_SERVER_URL=http://localhost:3001/mcp
FLIGHT_OPS_MCP_SERVER_LABEL=flight_ops

# agent-framework-dotnet lab (observability - Module 12)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
APPLICATIONINSIGHTS_CONNECTION_STRING=
