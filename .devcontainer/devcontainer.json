{
    "name": "Azure Developer CLI",
    "image": "mcr.microsoft.com/devcontainers/python:3.13",
    "features": {
        // See https://containers.dev/features for list of features
        "ghcr.io/azure/azure-dev/azd:latest": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/azure-cli:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.13",
            "installPip": true,
            "installPipx": true
        },
        "ghcr.io/devcontainers/features/powershell:1": {
            "version": "latest",
            "installAzModule": true
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/dotnet:2": {
            "version": "10.0"
        },
        // Docker-in-Docker enables building and pushing container images from inside
        // the dev container / Codespace. Required only for Module 09 Part 1 (deploy a
        // hosted agent from a container image); all other modules run without it.
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "christian-kohler.npm-intellisense",
                "davidanson.vscode-markdownlint",
                "dbaeumer.vscode-eslint",
                "editorconfig.editorconfig",
                "esbenp.prettier-vscode",
                "github.codespaces",
                "github.github-vscode-theme",
                "github.remotehub",
                "github.vscode-github-actions",
                "github.vscode-pull-request-github",
                "hediet.vscode-drawio",
                "humao.rest-client",
                "ise-hve-essentials.hve-core",
                "mikestead.dotenv",
                "ms-azuretools.azure-dev",
                "ms-azuretools.vscode-azure-github-copilot",
                "ms-azuretools.vscode-azure-mcp-server",
                "ms-azuretools.vscode-azureappservice",
                "ms-azuretools.vscode-azurecontainerapps",
                "ms-azuretools.vscode-azurefunctions",
                "ms-azuretools.vscode-azureresourcegroups",
                "ms-azuretools.vscode-azurestaticwebapps",
                "ms-azuretools.vscode-azurestorage",
                "ms-azuretools.vscode-azurevirtualmachines",
                "ms-azuretools.vscode-cosmosdb",
                "ms-azuretools.vscode-docker",
                "ms-python.debugpy",
                "ms-python.vscode-pylance",
                "ms-python.vscode-python-envs",
                "ms-vscode-remote.remote-containers",
                "ms-vscode.azure-repos",
                "ms-vscode.powershell",
                "ms-vscode.remote-repositories",
                "ms-vscode.vscode-node-azure-pack",
                "ms-windows-ai-studio.windows-ai-studio",
                "TeamsDevApp.ms-teams-vscode-extension",
                "orta.vscode-jest",
                "redhat.vscode-yaml",
                "vscode-icons-team.vscode-icons",
                "xabikos.javascriptsnippets",
                "ms-azuretools.vscode-bicep",
                "ms-vscode.azurecli",
                "ms-python.pylint",
                "ms-dotnettools.vscode-dotnet-pack",
                "ms-dotnettools.vscode-dotnet-runtime",
                "ms-dotnettools.csharp",
                "ms-dotnettools.csdevkit"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/python/current/bin/python3"
            }
        }
    },
    "forwardPorts": [
        // Forward ports if needed for local development
    ],
    "postCreateCommand": "./.devcontainer/post-create.sh",
    "remoteUser": "vscode",
    "hostRequirements": {
        "memory": "8gb"
    }
}
