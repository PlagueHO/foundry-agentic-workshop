// Configuration for markdownlint-cli2
{
  // Keep the CLI2 configuration self-contained so CI uses the repository rules.
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD029": {
      "style": "one"
    },
    "MD033": {
      "allowed_elements": ["br", "kbd", "details", "summary"]
    },
    "MD034": true,
    "MD036": false,
    "MD041": false,
    "MD060": false,
    "no-hard-tabs": true
  },
  // Ignore YAML front matter when applying Markdown rules
  "frontMatter": "(^---\\s*$[^]*?^---\\s*$)(\\r\\n|\\r|\\n|$)",
  // Files to lint (globs)
  "globs": [
    "**/*.md"
  ],
  // Files to ignore
  "ignores": [
    "**/node_modules/**",
    "**/coverage/**",
    "**/.vscode/**",
    "**/.github/instructions/**",
    "**/.azure/**",
    "**/.venv/**",
    "**/bin/**",
    "**/obj/**"
  ],
  // Output formatting
  "outputFormatters": [
    [
      "markdownlint-cli2-formatter-default"
    ]
  ]
}
