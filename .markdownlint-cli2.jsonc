// Configuration for markdownlint-cli2
{
  // Use the existing .markdownlint.json config
  "config": {
    "extends": ".markdownlint.json"
  },
  // Ignore YAML front matter when applying Markdown rules
  "frontMatter": "^(---\\r?\\n[\\s\\S]*?\\r?\\n---(?:\\r?\\n|$))",
  // Files to lint (globs)
  "globs": [
    "**/*.md"
  ],
  // Files to ignore
  "ignores": [
    "**/node_modules/**",
    "**/coverage/**",
    "**/.vscode/**",
    "**/.github/instructions/**",
    "**/.azure/**",
    "**/.venv/**",
    "**/bin/**",
    "**/obj/**"
  ],
  // Output formatting
  "outputFormatters": [
    [
      "markdownlint-cli2-formatter-default"
    ]
  ]
}
