{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "6047993598383393422"
    }
  },
  "parameters": {
    "botServiceName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "metadata": {
        "description": "The globally unique name of the Azure Bot Service resource."
      }
    },
    "displayName": {
      "type": "string",
      "defaultValue": "ACL Remedy Advisor",
      "metadata": {
        "description": "The display name shown for the bot."
      }
    },
    "appClientId": {
      "type": "string",
      "metadata": {
        "description": "The Microsoft Entra application (Microsoft App) client ID."
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "The Microsoft Entra tenant ID for the single-tenant bot."
      }
    },
    "messagingEndpoint": {
      "type": "string",
      "metadata": {
        "description": "The public HTTPS endpoint for the proxy, including /api/messages."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "The Azure region for the Bot Service resource."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "F0",
      "allowedValues": [
        "F0",
        "S1"
      ],
      "metadata": {
        "description": "The Bot Service SKU. F0 is sufficient for workshop testing."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Resource tags applied to the Bot Service."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.BotService/botServices",
      "apiVersion": "2022-09-15",
      "name": "[parameters('botServiceName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('skuName')]"
      },
      "kind": "azurebot",
      "properties": {
        "displayName": "[parameters('displayName')]",
        "endpoint": "[parameters('messagingEndpoint')]",
        "msaAppId": "[parameters('appClientId')]",
        "msaAppType": "SingleTenant",
        "msaAppTenantId": "[parameters('tenantId')]"
      }
    },
    {
      "type": "Microsoft.BotService/botServices/channels",
      "apiVersion": "2022-09-15",
      "name": "[format('{0}/{1}', parameters('botServiceName'), 'MsTeamsChannel')]",
      "location": "[parameters('location')]",
      "properties": {
        "channelName": "MsTeamsChannel"
      },
      "dependsOn": [
        "[resourceId('Microsoft.BotService/botServices', parameters('botServiceName'))]"
      ]
    }
  ],
  "outputs": {
    "botServiceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.BotService/botServices', parameters('botServiceName'))]"
    },
    "appClientId": {
      "type": "string",
      "value": "[parameters('appClientId')]"
    }
  }
}